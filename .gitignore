# ===== OS 잡파일 =====
.DS_Store
Thumbs.db
Desktop.ini

# ===== IDE 메타데이터(절대 올리지 않기) =====
# IntelliJ / IDEA
.idea/
*.iml
*.ipr
*.iws

# Eclipse / STS (Spring Tool Suite)
.project
.classpath
.settings/
.metadata/
bin/

# VS Code (원하면 커밋해도 되지만, 메타데이터 배제 원칙이면 제외)
.vscode/

# ===== Java / Spring Boot =====
# 빌드/캐시
target/
build/
out/
.gradle/

# Gradle Wrapper는 꼭 포함 (무시 금지)
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# Maven Wrapper는 포함 (무시 금지)
!.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

# 로그/패키징 산출물
logs/
*.log
*.log.*
*.jar
*.war
*.ear


# ===== Node / React (Vite, CRA 등) =====
node_modules/
dist/
build/
.cache/
.tmp/
.eslintcache
.parcel-cache/
.pnp.*
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 테스트 산출물
coverage/
cypress/videos/
cypress/screenshots/
.cypress-cache/

# ===== 환경변수 파일(비밀값) =====
.env
.env.*
!.env.example   # 예시만 커밋(선택)

# ===== 기타 =====
*.swp
*.swo
